{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "syntinel",
  "main": "src/workers.ts",
  "workers_dev": false,
  "preview_urls": false,
  "compatibility_date": "2026-05-31",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist/syntinel-angular/browser"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
