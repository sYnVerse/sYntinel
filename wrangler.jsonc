{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lucent",
  "main": "src/workers.ts",
  "workers_dev": false,
  "preview_urls": false,
  "compatibility_date": "2026-05-31",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist/syntinel-angular/browser",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
